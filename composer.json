{
    "name": "php-etl/bucket",
    "repositories": [
        {"type": "path", "url": "../../contracts/bucket-contracts"}
    ],
    "description": "This library implements the Extract-Transform-Load pattern asynchronously in PHP with the help of iterators and generators",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Kiboko SAS",
            "homepage": "http://kiboko.fr"
        },
        {
            "name": "Grégory Planchat",
            "email": "gregory@kiboko.fr"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "php-etl/bucket-contracts": "0.3.*"
    },
    "autoload": {
        "psr-4": {
            "Kiboko\\Component\\Bucket\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kiboko\\Component\\Bucket\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.4.x-dev"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.38",
        "rector/rector": "^2.3",
        "phpunit/phpunit": "^10.0"
    },
    "config": {
        "bin-dir": "bin"
    }
}
